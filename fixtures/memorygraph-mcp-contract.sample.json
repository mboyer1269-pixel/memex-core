{
  "tools": [
    {
      "name": "query_graph",
      "description": "Read-only query of the memory graph.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tenant": { "type": "string" },
          "namespace": { "type": "string" },
          "centerEntityId": { "type": "string" }
        },
        "required": ["tenant", "namespace", "centerEntityId"]
      }
    },
    {
      "name": "add_entity",
      "description": "Add a new entity to the graph.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "namespace": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["type", "namespace"]
      }
    }
  ]
}
